# --- DEPENDENCIES ---
# Mengabaikan library frontend yang diinstall via Bower
assets/bower_components/

# Mengabaikan folder vendor jika nanti menggunakan Composer
vendor/
node_modules/

# --- USER UPLOADS & DYNAMIC CONTENT ---
# Mengabaikan gambar yang diunggah oleh user agar tidak memenuhi repo
gambar/bukti_pembayaran/*
gambar/produk/*
gambar/user/*

# Kecuali file .gitkeep (agar struktur folder tetap ada di Git)
!gambar/bukti_pembayaran/.gitkeep
!gambar/produk/.gitkeep
!gambar/user/.gitkeep

# --- OS ARTIFACTS ---
# Mengabaikan file sampah bawaan OS (banyak ditemukan .DS_Store di folder Anda)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- IDE & TOOLS ---
.idea/
.vscode/
*.swp
*.bak
.laragon/

# --- LOGS & TEMP ---
*.log
error_log
npm-debug.log*
yarn-debug.log*
yarn-error.log*